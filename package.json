{
  "name": "miru",
  "version": "0.0.0",
  "private": "true",
  "packageManager": "pnpm@10.12.4",
  "type": "module",
  "scripts": {
    "dev": "pnpm run website:build --serve",
    "dev:slow": "VITE_DEV_SLOW_DOWN_MS=5000 pnpm run dev",
    "libs:build": "NODE_ENV=production rollup --config config/rollup.config.js",
    "libs:build:dev": "NODE_ENV=development rollup --config config/rollup.config.js",
    "check": "vue-tsc -b config/tsconfig.check.json --incremental",
    "lint:css": "stylelint --ignore-path .gitignore '**/*.{css,scss}'",
    "lint:markdown": "markdownlint --ignore-path .gitignore --ignore '**/CHANGELOG.md' '**/*.md'",
    "lint:prettier": "prettier --check '**/*.{ts,js,tsx,jsx,cjs,vue,md,html,yaml,yml,json}'",
    "lint": "pnpm run lint:css && pnpm run lint:markdown && pnpm eslint --quiet && pnpm run lint:prettier",
    "lint:fix": "pnpm run lint:css --fix && pnpm run lint:markdown --fix && pnpm eslint --quiet --fix && pnpm lint:prettier --write",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
    "prepare": "husky",
    "website:build": "rm -r website/.11ty-vite; pnpm --prefix website exec eleventy --config=eleventy.config.ts",
    "gltf-optimize": "node --experimental-strip-types ./scripts/gltf-optimize.js",
    "update-deps": "taze minor --recursive --interactive --write --install --update && pnpm dedupe",
    "test": "vitest run"
  },
  "author": "Taye Adeyemi",
  "license": "AGPL-3.0-only",
  "dependencies": {
    "@unocss/reset": "^66.5.0",
    "compare-palettes": "workspace:^",
    "filesize": "^10.1.6",
    "gltf-ar-effects": "workspace:^",
    "reactive-effects": "workspace:^",
    "shared": "workspace:^",
    "uid": "catalog:",
    "unplugin-vue-markdown": "^29.2.0",
    "vitest": "^4.0.18",
    "vue": "catalog:",
    "vue-i18n-lite": "catalog:",
    "webgl-video-editor": "workspace:^"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@eslint/js": "^9.39.4",
    "@eslint/markdown": "^7.5.1",
    "@gltf-transform/cli": "catalog:",
    "@gltf-transform/core": "catalog:",
    "@gltf-transform/extensions": "catalog:",
    "@gltf-transform/functions": "catalog:",
    "@iconify-json/devicon-plain": "^1.2.56",
    "@iconify-json/material-symbols": "^1.2.63",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/tabler": "^1.2.22",
    "@lokesh.dhakar/quantize": "catalog:",
    "@rollup/plugin-alias": "^5.1.1",
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-replace": "^6.0.2",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-url": "^8.0.2",
    "@svgr/core": "^8.1.0",
    "@svgr/plugin-jsx": "^8.1.0",
    "@types/color-diff": "^1.2.5",
    "@types/debug": "^4.1.12",
    "@types/dom-webcodecs": "^0.1.16",
    "@types/json-pointer": "^1.0.34",
    "@types/node": "^24.3.0",
    "@types/quantize": "^1.0.2",
    "@types/semver": "^7.7.0",
    "@types/stats.js": "^0.17.4",
    "@types/three": "catalog:",
    "@types/throttle-debounce": "^5.0.2",
    "@unocss/preset-icons": "^66.5.0",
    "@vitejs/plugin-basic-ssl": "^2.1.0",
    "@vitejs/plugin-vue": "catalog:",
    "@vitest/coverage-v8": "4.0.18",
    "@vue/runtime-core": "^3.5.26",
    "color-diff": "catalog:",
    "conventional-changelog-cli": "^5.0.0",
    "conventional-recommended-bump": "^11.2.0",
    "cssnano": "^7.1.1",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.4",
    "eslint-config-love": "^151.0.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^62.7.1",
    "fine-jsx": "catalog:",
    "glob": "^13.0.0",
    "globals": "^17.4.0",
    "glslify": "^7.1.1",
    "happy-dom": "^20.0.11",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "markdown-it-task-lists": "^2.1.1",
    "markdownlint-cli": "^0.48.0",
    "nano-spawn": "^1.0.2",
    "picocolors": "^1.1.1",
    "postcss": "^8.5.6",
    "postcss-hover-media-feature": "^1.0.2",
    "postcss-import": "^16.1.1",
    "postcss-load-config": "^6.0.1",
    "postcss-preset-env": "^10.3.1",
    "postcss-url": "^10.1.3",
    "prettier": "^3.8.1",
    "prettier-plugin-jinja-template": "^2.1.0",
    "prettier-plugin-jsdoc": "^1.8.0",
    "rollup": "^4.50.0",
    "rollup-plugin-analyzer": "^4.0.0",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-delete": "^3.0.1",
    "rollup-plugin-dts": "^6.2.3",
    "rollup-plugin-esbuild-transform": "^1.5.0",
    "rollup-plugin-external-assets": "^4.1.1",
    "rollup-plugin-filesize": "^10.0.0",
    "rollup-plugin-glob-import": "^0.5.0",
    "rollup-plugin-glsl-optimize": "^1.0.4",
    "rollup-plugin-postcss": "^4.0.2",
    "sass-embedded": "^1.92.0",
    "semver": "^7.7.2",
    "sharp": "^0.34.3",
    "stats.js": "catalog:",
    "stylelint": "^17.4.0",
    "stylelint-config-css-modules": "^4.6.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-recess-order": "^7.6.1",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-order": "^7.0.1",
    "stylelint-prettier": "^5.0.3",
    "taze": "^19.4.0",
    "terser": "^5.43.1",
    "throttle-debounce": "catalog:",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "unocss": "^66.5.0",
    "unplugin-auto-import": "^19.3.0",
    "unplugin-icons": "^22.2.0",
    "vite": "catalog:",
    "vite-bundle-analyzer": "^0.23.0",
    "vite-plugin-remote-assets": "^2.1.0",
    "vue-tsc": "^3.2.2"
  },
  "lint-staged": {
    "**/*.((ts|js|cjs)?(x)|vue)": [
      "eslint --quiet --fix",
      "prettier --check --write"
    ],
    "**/*.{md,njk}": [
      "eslint --quiet --fix",
      "markdownlint --fix",
      "prettier --check --write"
    ],
    "**/*.{css,scss}": "stylelint --fix",
    "**/*.(yaml|yml|json)": "prettier --check --write"
  },
  "browserslist": [
    "fully supports es6-module and fully supports webgl2",
    "maintained node versions"
  ],
  "pnpm": {
    "patchedDependencies": {
      "glsl-tokenizer": "patches/glsl-tokenizer.patch",
      "libavjs-webcodecs-polyfill": "patches/libavjs-webcodecs-polyfill.patch",
      "@interactjs/core": "patches/@interactjs__core.patch"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "rollup-plugin-glsl-optimize"
    ]
  }
}
