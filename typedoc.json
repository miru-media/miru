{
  // Note: In TypeDoc 0.26 you can instead specify `packageOptions` if running
  // only with packages mode. The separate base config file is retained in this
  // example so that individual packages can be built for demonstration of the
  // advanced method in the readme.

  "$schema": "https://typedoc.org/schema.json",
  "entryPointStrategy": "packages",
  "entryPoints": [
    "./packages/webgl-video-editor",
    "./packages/webgl-media-editor",
    "./packages/media-trimmer"
  ],
  "packageOptions": {
    "entryPoints": ["src/index.ts"],
    "readme": "none",
    "includeVersion": true,
    "tsconfig": "../../config/tsconfig.typedoc.json"
  },
  "excludeInternal": true,
  "readme": "none",
  "router": "kind-dir",
  "plugin": ["./scripts/typedoc-theme.ts"],
  "out": "./website/content/api"
}
